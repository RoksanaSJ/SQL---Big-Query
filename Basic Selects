#All days where the average queue wait time was greater than 120 seconds, sorted in descending order by the average wait time.
SELECT DateID, AvgQueueTimeSec
FROM `linen-striker-481210-m7.Zadanie1.fact_store_day_ops`
WHERE AvgQueueTimeSec > 120 
ORDER BY AvgQueueTimeSec DESC

#Find campaigns whose name contains the word 'Local'.
SELECT * 
FROM linen-striker-481210-m7.Zadanie1.dim_campaign
WHERE CampaignName LIKE '%Local%'

#Display cafes where the 'country' is 'CZ'.
SELECT *
FROM linen-striker-481210-m7.Zadanie1.dim_store
WHERE Country LIKE 'CZ'

#Show records from the fact table where there is no campaign (CampaignID is NULL).
SELECT *
FROM linen-striker-481210-m7.Zadanie1.fact_store_day_ops
WHERE CampaignID IS NULL

#Find campaigns whose name does not contain the word 'Student'.
SELECT *
FROM linen-striker-481210-m7.Zadanie1.dim_campaign
WHERE CampaignName NOT LIKE '%Student%'

#Show the days from the fact table where there were more than 5 employees on shift.
SELECT DateID, StaffOnShiftCount
FROM linen-striker-481210-m7.Zadanie1.fact_store_day_ops
WHERE StaffOnShiftCount > 5
