#Wszystkie dni, w których średni czas oczekiwania w kolejce był większy niż 120 sekund, posortowane malejąco według średniego czasu oczekiwania.
SELECT DateID, AvgQueueTimeSec
FROM `linen-striker-481210-m7.Zadanie1.fact_store_day_ops`
WHERE AvgQueueTimeSec > 120 
ORDER BY AvgQueueTimeSec DESC

